generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum NotebookStatus {
  DRAFT
  PENDING
  PROCESSING
  READY
  FAILED
}

enum ArtifactType {
  OUTLINE
  SUMMARY_SHORT
  SUMMARY_MEDIUM
  STUDY_GUIDE
  FLASHCARDS
  QUIZ
  MIND_MAP
}

enum ArtifactStatus {
  EMPTY
  GENERATING
  READY
  FAILED
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
}

enum JobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum EvidenceSourceType {
  CAPTION
  AUTO_CAPTION
  ASR
  METADATA
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  notebooks     Notebook[]
  jobs          Job[]
  chatMessages  ChatMessage[]
  preference    UserPreference?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@unique([userId, provider])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Notebook {
  id           String         @id @default(cuid())
  userId       String
  title        String
  sourceUrl    String
  videoId      String?
  videoTitle   String?
  thumbnailUrl String?
  durationSec  Int?
  language     String         @default("en")
  status       NotebookStatus @default(DRAFT)
  errorType    String?
  errorMessage String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  artifacts        Artifact[]
  chatMessages     ChatMessage[]
  jobs             Job[]
  evidenceSegments EvidenceSegment[]

  @@index([userId, createdAt])
}

model Artifact {
  id                 String         @id @default(cuid())
  notebookId         String
  type               ArtifactType
  language           String         @default("en")
  json               Json?
  status             ArtifactStatus @default(EMPTY)
  errorType          String?
  errorMessage       String?
  generatedBy        String?
  verifiedAt         DateTime?
  sourceSegmentCount Int?
  metadata           Json?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  notebook Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)

  @@unique([notebookId, type, language])
  @@index([notebookId])
}

model ChatMessage {
  id            String   @id @default(cuid())
  notebookId    String
  userId        String?
  role          ChatRole
  content       String   @db.Text
  citationsJson Json?
  createdAt     DateTime @default(now())

  notebook Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([notebookId, createdAt])
}

model Job {
  id               String    @id @default(cuid())
  notebookId       String
  userId           String?
  type             String
  status           JobStatus @default(QUEUED)
  progress         Int       @default(0)
  progressPercent  Int       @default(0)
  currentStep      String?
  errorType        String?
  errorMessage     String?
  errorCode        String?
  safeErrorMessage String?
  attempts         Int       @default(0)
  attemptCount     Int       @default(0)
  maxAttempts      Int       @default(2)
  startedAt        DateTime?
  finishedAt       DateTime?
  metadata         Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  notebook Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([notebookId, status])
  @@index([userId, status])
  @@index([type, status])
}

model EvidenceSegment {
  id               String             @id @default(cuid())
  notebookId       String
  videoId          String
  startSec         Float
  endSec           Float
  text             String             @db.Text
  sourceType       EvidenceSourceType
  confidence       Float              @default(1.0)
  language         String?
  extractionEngine String?
  rawSource        String?
  embeddingStatus  String             @default("PENDING")
  embeddingModel   String?
  embeddingErrorCode String?
  embeddingErrorMessage String?
  indexedAt        DateTime?
  searchDocumentId String?
  createdAt        DateTime           @default(now())

  notebook Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)

  @@index([notebookId, startSec])
  @@index([notebookId, embeddingStatus])
  @@index([notebookId, indexedAt])
  @@index([videoId])
}

model UserPreference {
  id              String @id @default(cuid())
  userId          String @unique
  theme           String @default("system")
  defaultLanguage String @default("en")
  chatMode        String @default("default")
  responseLength  String @default("default")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FacultySession {
  id             String   @id @default(cuid())
  workspaceId    String   @unique
  lectureUrl     String?
  status         String   @default("created")
  azureNamespace String   @unique
  createdAt      DateTime @default(now())
  lastActiveAt   DateTime @default(now())
  expiresAt      DateTime
  deletedAt      DateTime?

  workspace      FacultyWorkspace?
  uploads        FacultyUpload[]
  artifacts      FacultyArtifact[]
  chatMessages   FacultyChatMessage[]

  @@index([expiresAt])
  @@index([lastActiveAt])
  @@index([deletedAt])
}

model FacultyWorkspace {
  id             String   @id @default(cuid())
  sessionId      String   @unique
  title          String?
  lectureUrl     String
  transcriptText String?
  segmentCount   Int      @default(0)
  indexedCount   Int      @default(0)
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  session        FacultySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([status])
}

model FacultyUpload {
  id              String   @id @default(cuid())
  sessionId       String
  originalName    String
  mimeType        String
  sizeBytes       Int
  storageKey      String
  ocrStatus       String   @default("pending")
  ocrText         String?
  ocrJson         Json?
  confidenceScore Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  session         FacultySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([ocrStatus])
}

model FacultyArtifact {
  id             String   @id @default(cuid())
  sessionId      String
  type           String
  status         String   @default("pending")
  title          String?
  json           Json?
  storageKey     String?
  errorCode      String?
  errorMessage   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  session        FacultySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([type])
  @@unique([sessionId, type])
}

model FacultyChatMessage {
  id             String   @id @default(cuid())
  sessionId      String
  role           String
  content        String
  citations      Json?
  createdAt      DateTime @default(now())

  session        FacultySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
}
