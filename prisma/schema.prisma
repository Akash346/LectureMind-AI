generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum NotebookStatus {
  DRAFT
  PENDING
  PROCESSING
  READY
  FAILED
}

enum ArtifactType {
  OUTLINE
  SUMMARY_SHORT
  SUMMARY_MEDIUM
  STUDY_GUIDE
  FLASHCARDS
  QUIZ
  MIND_MAP
}

enum ArtifactStatus {
  EMPTY
  GENERATING
  READY
  FAILED
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
}

enum JobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum EvidenceSourceType {
  CAPTION
  AUTO_CAPTION
  ASR
  METADATA
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  notebooks     Notebook[]
  chatMessages  ChatMessage[]
  preference    UserPreference?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Notebook {
  id           String         @id @default(cuid())
  userId       String
  title        String
  sourceUrl    String
  videoId      String?
  videoTitle   String?
  thumbnailUrl String?
  durationSec  Int?
  language     String         @default("en")
  status       NotebookStatus @default(DRAFT)
  errorType    String?
  errorMessage String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  artifacts        Artifact[]
  chatMessages     ChatMessage[]
  jobs             Job[]
  evidenceSegments EvidenceSegment[]

  @@index([userId, createdAt])
}

model Artifact {
  id         String         @id @default(cuid())
  notebookId String
  type       ArtifactType
  language   String         @default("en")
  json       Json?
  status     ArtifactStatus @default(EMPTY)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  notebook Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)

  @@unique([notebookId, type, language])
  @@index([notebookId])
}

model ChatMessage {
  id            String   @id @default(cuid())
  notebookId    String
  userId        String?
  role          ChatRole
  content       String   @db.Text
  citationsJson Json?
  createdAt     DateTime @default(now())

  notebook Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([notebookId, createdAt])
}

model Job {
  id           String    @id @default(cuid())
  notebookId   String
  type         String
  status       JobStatus @default(QUEUED)
  progress     Int       @default(0)
  currentStep  String?
  errorType    String?
  errorMessage String?
  attempts     Int       @default(0)
  startedAt    DateTime?
  finishedAt   DateTime?
  metadata     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  notebook Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)

  @@index([notebookId, status])
}

model EvidenceSegment {
  id               String             @id @default(cuid())
  notebookId       String
  videoId          String
  startSec         Float
  endSec           Float
  text             String             @db.Text
  sourceType       EvidenceSourceType
  confidence       Float              @default(1.0)
  language         String?
  extractionEngine String?
  rawSource        String?
  createdAt        DateTime           @default(now())

  notebook Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)

  @@index([notebookId, startSec])
  @@index([videoId])
}

model UserPreference {
  id              String @id @default(cuid())
  userId          String @unique
  theme           String @default("system")
  defaultLanguage String @default("en")
  chatMode        String @default("default")
  responseLength  String @default("default")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
