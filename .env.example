# LectureMind AI example environment
# Copy this file to .env for local development. The app never reads
# .env.example at runtime.

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/lecturemind_ai?schema=public"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

AZURE_OPENAI_ENDPOINT="https://YOUR-RESOURCE.openai.azure.com"
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_API_VERSION="2024-10-21"
AZURE_OPENAI_DEPLOYMENT_FAST=""
AZURE_OPENAI_DEPLOYMENT_STRONG=""
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=""
AZURE_OPENAI_EMBEDDING_DIMENSIONS="1536"

AZURE_SEARCH_ENDPOINT="https://YOUR-SEARCH.search.windows.net"
AZURE_SEARCH_API_KEY=""
AZURE_SEARCH_INDEX_NAME="lecturemind-evidence-dev"
# Legacy aliases are also accepted. Prefer canonical names above.
# AZURE_AI_SEARCH_ENDPOINT=""
# AZURE_AI_SEARCH_API_KEY=""
# AZURE_AI_SEARCH_INDEX="lecturemind-index"

AZURE_STORAGE_CONNECTION_STRING=""
AZURE_STORAGE_CONTAINER=""

AZURE_SPEECH_KEY=""
AZURE_SPEECH_REGION=""
AZURE_SPEECH_LANGUAGE="en-US"

ENABLE_AZURE_SPEECH_FALLBACK="true"
ENABLE_YTDLP_WORKER="true"
INGESTION_ENGINE="hybrid"
PYTHON_WORKER_URL="http://localhost:8000"
WORKER_SHARED_SECRET=""

# Optional server-side diagnostics. Never enable this for public logs.
DEBUG_AI="false"
